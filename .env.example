# ⚠️ Copy to .env and fill in values. NEVER commit .env!

# Target
TARGET=https://example.com
DOMAIN=example.com

# Paths (for SAST, Secrets, Binary)
CODE=/path/to/source/code
REPO=/path/to/git/repo
BIN=/path/to/binary
BIN_DIR=/path/to/binaries/directory
IMAGE=myapp:latest

# Nuclei
RATE_LIMIT=50

# LLM (garak)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-3.5-turbo
LLM_TYPE=openai

# DefectDojo
DEFECTDOJO_DB_PASSWORD=changeme
DD_SECRET_KEY=changeme-in-production
DD_AES_KEY=changeme-in-production-too
